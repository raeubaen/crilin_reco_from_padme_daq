          "peak_pos_from_highest_ch": false,
          "signal_samples_pre_peak": 100,
          "signal_samples_post_peak": 500,
          "charge_zerosup_peak_threshold": 3,
          "do_timing": true,
          "timing_methods": [
            "cf"
          ],
          "interpolation_factor": 40,
          "cf": 0.11,
          "rise_samples_pre_peak": 30,
          "rise_samples_post_peak": 30,
          "rise_interp_left_samples": 3,
          "rise_interp_right_samples": 3,
          "sampling_rate": 2.5,
